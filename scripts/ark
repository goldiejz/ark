#!/usr/bin/env bash
# ark — Single command to activate the agentic OS in any project
#
# Usage (from any sub-project directory):
#   ark                    # Default: sync + show status
#   ark sync               # Pull latest vault, refresh snapshot
#   ark bootstrap          # Run new project bootstrap
#   ark status             # Show current snapshot state
#   ark insights           # Show latest cross-project insights
#   ark lessons            # List all lessons available
#   ark phase-6            # Trigger Phase 6 daemon manually
#   ark init               # Initialize .parent-automation in current project
#
# Install once:
#   ln -sf ~/vaults/ark/scripts/ark /usr/local/bin/ark

set -euo pipefail

VAULT_PATH="${ARK_HOME:-$HOME/vaults/ark}"
COMMAND="${1:-default}"
PROJECT_DIR="$(pwd)"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

print_header() {
  echo -e "${BLUE}🚢 ARK${NC}"
  echo -e "   Vault: $VAULT_PATH"
  echo -e "   Project: $PROJECT_DIR"
  echo ""
}

cmd_sync() {
  print_header
  bash "$VAULT_PATH/scripts/ark-sync.sh" "$PROJECT_DIR"
}

cmd_status() {
  print_header
  # Support both legacy 'brain-snapshot' and new 'ark-snapshot' dir names during transition
  local manifest=""
  if [[ -f "$PROJECT_DIR/.parent-automation/ark-snapshot/SNAPSHOT-MANIFEST.json" ]]; then
    manifest="$PROJECT_DIR/.parent-automation/ark-snapshot/SNAPSHOT-MANIFEST.json"
  elif [[ -f "$PROJECT_DIR/.parent-automation/brain-snapshot/SNAPSHOT-MANIFEST.json" ]]; then
    manifest="$PROJECT_DIR/.parent-automation/brain-snapshot/SNAPSHOT-MANIFEST.json"
  fi

  if [[ -n "$manifest" ]]; then
    echo -e "${GREEN}✅ Snapshot present${NC}"
    cat "$manifest" | head -20
  else
    echo -e "${YELLOW}⚠️  No snapshot yet. Run: ark sync${NC}"
  fi
  echo ""
  if [[ -f "$PROJECT_DIR/.planning/bootstrap-decisions.jsonl" ]]; then
    DECISIONS=$(wc -l < "$PROJECT_DIR/.planning/bootstrap-decisions.jsonl" | tr -d ' ')
    echo -e "${GREEN}✅ Decisions logged: $DECISIONS${NC}"
  else
    echo -e "${YELLOW}⚠️  No decision log yet${NC}"
  fi
}

cmd_bootstrap() {
  print_header
  if [[ ! -f "$PROJECT_DIR/.parent-automation/new-project-bootstrap-v2.ts" ]]; then
    echo -e "${RED}❌ No bootstrap script found. Run: ark init${NC}"
    exit 1
  fi
  cd "$PROJECT_DIR/.parent-automation"
  npx --yes tsx new-project-bootstrap-v2.ts
}

cmd_insights() {
  print_header
  echo -e "${BLUE}📊 Cross-Project Insights:${NC}"
  echo ""
  if [[ -f "$VAULT_PATH/observability/cross-customer-insights.md" ]]; then
    cat "$VAULT_PATH/observability/cross-customer-insights.md" | head -60
  else
    echo "No insights yet. Run: ark phase-6"
  fi
}

cmd_lessons() {
  print_header
  echo -e "${BLUE}📚 Available Lessons:${NC}"
  echo ""
  # Disable pipefail temporarily — head -30 closing pipe is intentional
  set +o pipefail
  find "$VAULT_PATH/lessons" -name "*.md" -type f 2>/dev/null | head -30 | while read -r f; do
    title=$(grep -m1 "^# " "$f" 2>/dev/null | sed 's/^# //' || basename "$f")
    echo "  • $title"
  done
  set -o pipefail
  echo ""
  TOTAL=$(find "$VAULT_PATH/lessons" -name "*.md" -type f 2>/dev/null | wc -l | tr -d ' ')
  echo "  Total: $TOTAL lessons"
}

cmd_phase6() {
  print_header
  echo -e "${BLUE}🔄 Running Phase 6 daemon...${NC}"
  cd "$VAULT_PATH"
  npx ts-node observability/phase-6-daemon.ts
}

cmd_init() {
  print_header
  echo -e "${BLUE}🆕 Initializing .parent-automation in $PROJECT_DIR${NC}"
  echo ""

  # Templates live in the vault — single source of truth
  TEMPLATE_DIR="$VAULT_PATH/templates/parent-automation"
  if [[ ! -d "$TEMPLATE_DIR" ]]; then
    echo -e "${RED}❌ Template dir missing: $TEMPLATE_DIR${NC}"
    echo "   Run: ark sync (to refresh vault)"
    exit 1
  fi

  ALREADY_INITIALIZED=false
  if [[ -d "$PROJECT_DIR/.parent-automation" ]]; then
    ALREADY_INITIALIZED=true
    echo -e "${YELLOW}⚠️  .parent-automation already exists${NC}"
    echo "   Will only update modules + sync snapshot (preserves your customizations)"
    echo ""
  fi

  mkdir -p "$PROJECT_DIR/.parent-automation"
  mkdir -p "$PROJECT_DIR/.planning"

  # Copy bootstrap and query modules from vault templates
  # Use rsync with --update to only copy if newer
  for file in query-brain.ts new-project-bootstrap-v2.ts tsconfig.json; do
    SRC="$TEMPLATE_DIR/$file"
    DST="$PROJECT_DIR/.parent-automation/$file"
    if [[ "$SRC" -ef "$DST" ]]; then
      echo "  ⏭  $file: skipping (source = destination)"
      continue
    fi
    if [[ -f "$DST" ]] && cmp -s "$SRC" "$DST"; then
      echo "  ✅ $file: already up to date"
    else
      cp "$SRC" "$DST"
      echo "  ✅ $file: updated from vault"
    fi
  done

  # Initialize decision log if missing
  if [[ ! -f "$PROJECT_DIR/.planning/bootstrap-decisions.jsonl" ]]; then
    touch "$PROJECT_DIR/.planning/bootstrap-decisions.jsonl"
    echo "  ✅ Created .planning/bootstrap-decisions.jsonl"
  fi

  # Run sync to populate/refresh snapshot
  echo ""
  bash "$VAULT_PATH/scripts/ark-sync.sh" "$PROJECT_DIR"

  echo ""
  if [[ "$ALREADY_INITIALIZED" == "true" ]]; then
    echo -e "${GREEN}✅ Updated! Next steps:${NC}"
  else
    echo -e "${GREEN}✅ Initialized! Next steps:${NC}"
  fi
  echo "  ark bootstrap   # Run bootstrap workflow"
  echo "  ark status      # Check state"
}

cmd_help() {
  cat <<EOF
🚢 ARK — Single command interface

Usage: ark [command]

Commands:
  AUTONOMOUS DELIVERY:
    create      Scaffold a new project. Two invocation modes:
                  Description mode (Phase 4 — recommended):
                    ark create "<one-line description>" --customer <name>
                  Flag mode (backward compatible):
                    ark create <name> --type <t> --stack <s> --deploy <d> --customer <c>
                  See 'ark create --help' for full options.
    deliver     Run autonomous delivery. With no args from outside a project, picks portfolio winner.
    promote     Deploy to staging or production (production requires --confirm)

  PROJECT MANAGEMENT:
    init        Initialize .parent-automation in current project
    align       Standardize imported project to canonical structure
    bootstrap   Record bootstrap decision (manual)
    sync        Pull latest vault, refresh local snapshot
    secrets     Set up secrets management for current deploy target
    lifecycle   Project lifecycle: status|archive|maintain|sunset|revive

  GOVERNANCE:
    budget       Token usage tracking and budget caps
    escalations  List/show/resolve queued blockers (~/vaults/ark/ESCALATIONS.md)
    portfolio   CEO dashboard across all brain-integrated projects
    report      Stakeholder reports (--for customer|investor|team|self)

  HEALTH & MAINTENANCE:
    status      Show snapshot + decision log state
    doctor      Comprehensive health check
    backup      Create timestamped vault backup
    validate    Detect drift in cached templates
    observe     Continuous monitoring + pattern detection (long-running daemon)
    continuous  Continuous-operation agent (launchd-driven). Subcommands:
                  install | uninstall | status | pause | resume | tick
                  Run 'ark continuous --help' for full usage + INBOX format.

  OBSERVABILITY:
    dashboard   CEO dashboard (read-only). Default: bash version (Tier A, <2s).
                  Flag: --tui  Live Rust TUI with vim keybindings (requires Rust build).
                  Flag: --web  Local web dashboard via python3 http.server (default port 7919).
    insights    Show cross-project insights from Phase 6
    lessons     List all lessons in the ark
    learn       Run the policy-learner (--full | --since DATE; default: last 7 days)
    promote-lessons  Promote cross-customer lessons (--full | --since DATE | --dry-run; default: last 7 days)
    phase-6     Manually trigger Phase 6 observability daemon

  help          Show this help

Environment:
  ARK_HOME            Path to vault (default: ~/vaults/ark)
  ARK_PORTFOLIO_ROOT  Root for 'ark deliver' no-args portfolio scan (default: ~/code)
  ARK_CREATE_GITHUB   When 'true', 'ark create' provisions a real GitHub repo
                      via 'gh repo create'. Default off — production
                      side-effect gate (see Phase 4 04-04 incident report).

Examples:
  cd ~/code/my-project && ark          # Sync and show status
  ark bootstrap                         # Run bootstrap
  ark insights                          # See cross-project patterns
EOF
}

cmd_align() {
  print_header
  shift_args=("${@:2}")
  bash "$VAULT_PATH/scripts/ark-align.sh" "${shift_args[@]:-$PROJECT_DIR}"
}

cmd_continuous() {
  # Phase 7 Plan 07-05 — pure pass-through to scripts/ark-continuous.sh.
  # Mirrors `ark dashboard` / `ark promote-lessons` wiring patterns: zero
  # business logic in the dispatcher; subshell exit codes propagate.
  local sub="${1:-}"
  shift || true

  if [[ ! -f "$VAULT_PATH/scripts/ark-continuous.sh" ]]; then
    echo -e "${RED}❌ scripts/ark-continuous.sh not found — Phase 7 not yet installed${NC}" >&2
    exit 1
  fi

  case "$sub" in
    install)   bash "$VAULT_PATH/scripts/ark-continuous.sh" --install "$@" ;;
    uninstall) bash "$VAULT_PATH/scripts/ark-continuous.sh" --uninstall "$@" ;;
    status)    bash "$VAULT_PATH/scripts/ark-continuous.sh" --status "$@" ;;
    pause)     bash "$VAULT_PATH/scripts/ark-continuous.sh" --pause "$@" ;;
    resume)    bash "$VAULT_PATH/scripts/ark-continuous.sh" --resume "$@" ;;
    tick)      bash "$VAULT_PATH/scripts/ark-continuous.sh" --tick "$@" ;;
    ""|help|-h|--help)
      cat >&2 <<EOF
usage: ark continuous <subcommand>

Subcommands:
  install     generate + load ~/Library/LaunchAgents/com.ark.continuous.plist
  uninstall   unload + remove the launchd agent + plist
  status      show last tick / next tick / recent decisions / daily tokens
  pause       create PAUSE file (kill-switch — agent skips ticks while present)
  resume      remove PAUSE file (resume scheduled ticks)
  tick        run one tick manually (for debugging)

INBOX:
  Drop tasks into ~/vaults/ark/INBOX/ as plain-text or markdown files.
  Each tick scans the INBOX, dispatches work, and archives processed items.

Environment:
  ARK_LAUNCHAGENTS_DIR  Override LaunchAgents dir (test isolation)
  ARK_HOME              Override vault path (default: ~/vaults/ark)
EOF
      return 2
      ;;
    *)
      echo "unknown subcommand: $sub" >&2
      echo "run 'ark continuous --help' for usage" >&2
      return 2
      ;;
  esac
}

cmd_create() {
  # Pass through all args (positional + flags) to ark-create.sh.
  # ark-create.sh handles description-mode vs flag-mode disambiguation internally:
  #   ark create "<one-line description>" --customer <name>           # description mode (Phase 4)
  #   ark create <name> --type <t> --stack <s> --deploy <d> --customer <c>   # flag mode (legacy)
  # Production-side-effect gate: GitHub repo creation only fires when
  # ARK_CREATE_GITHUB=true (default off; see Phase 4 04-04 incident report).
  exec bash "$VAULT_PATH/scripts/ark-create.sh" "$@"
}

# Default command: sync + status
case "$COMMAND" in
  default|"")
    cmd_sync
    echo ""
    cmd_status
    ;;
  sync)       cmd_sync ;;
  status)     cmd_status ;;
  bootstrap)  cmd_bootstrap ;;
  align)      cmd_align "$@" ;;
  doctor)     bash "$VAULT_PATH/scripts/ark-doctor.sh" ;;
  verify)     shift; bash "$VAULT_PATH/scripts/ark-verify.sh" "$@" ;;
  dashboard)
    shift
    # Tier A (bash, default) vs Tier B (Rust TUI, --tui flag).
    # Phase 6.5 — REQ-DASH-01 (bash invocation), REQ-DASH-06 (TUI invocation).
    # Both tiers are read-only over policy.db; mark-resolved flows route
    # through 'ark escalations --resolve <id>' (single-writer path).
    case "${1:-}" in
      --tui)
        shift
        _tui_bin="$VAULT_PATH/scripts/ark-dashboard/target/release/ark-dashboard"
        if [[ ! -x "$_tui_bin" ]]; then
          echo -e "${RED}❌ TUI binary not built.${NC}" >&2
          echo "   Run: cd $VAULT_PATH/scripts/ark-dashboard && cargo build --release" >&2
          echo "   (Tier B requires the Rust toolchain. Default 'ark dashboard' uses the bash version.)" >&2
          exit 1
        fi
        exec "$_tui_bin" "$@"
        ;;
      --web)
        # Tier C — local web dashboard (bash + python3 http.server).
        # Phase 6.5 — REQ-DASH-09, REQ-DASH-10.
        shift
        _web_port="7919"
        if [[ "${1:-}" == "--port" ]]; then
          shift
          _web_port="${1:-7919}"
          shift || true
        fi
        if [[ ! -f "$VAULT_PATH/scripts/ark-dashboard-web.sh" ]]; then
          echo -e "${RED}❌ Tier C web dashboard not yet installed${NC}" >&2
          echo "   Expected: $VAULT_PATH/scripts/ark-dashboard-web.sh" >&2
          exit 1
        fi
        ARK_DASHBOARD_PORT="$_web_port" exec bash "$VAULT_PATH/scripts/ark-dashboard-web.sh"
        ;;
      --help|-h)
        cat <<EOF
ark dashboard — CEO dashboard (read-only over vault audit data)

Usage:
  ark dashboard              Tier A bash dashboard (default, <2s, 7 sections)
  ark dashboard --tui        Tier B live Rust TUI (vim keybindings, 2s polling)
  ark dashboard --web        Tier C local web dashboard (browser, auto-refresh 5s)
                               --port N   Override default port 7919
                               (also honors ARK_DASHBOARD_PORT env)
  ark dashboard --help       Show this help

Tier A flags (passed through to scripts/ark-dashboard.sh):
  --no-color                 Strip ANSI escapes (also honors NO_COLOR env)
  --section <name>           Render a single section only

Tier B requires the Rust toolchain. Build once with:
  cd $VAULT_PATH/scripts/ark-dashboard && cargo build --release

Tier C uses python3 stdlib http.server (no extra deps). Read-only over the
same data sources as Tier A. Browser auto-refreshes via <meta refresh>.

All three tiers are strictly read-only. Mark-resolved actions route through
'ark escalations --resolve <id>' (single-writer audit path).
EOF
        exit 0
        ;;
      --*)
        # Unknown long flag → reject before passthrough
        if [[ "${1:-}" != "--no-color" && "${1:-}" != "--section" ]]; then
          echo -e "${RED}❌ Unknown flag for 'ark dashboard': $1${NC}" >&2
          echo "Usage: ark dashboard [--tui | --help | --no-color | --section <name>]" >&2
          exit 1
        fi
        if [[ ! -f "$VAULT_PATH/scripts/ark-dashboard.sh" ]]; then
          echo -e "${RED}❌ scripts/ark-dashboard.sh not found — Phase 6.5 not yet installed${NC}" >&2
          exit 1
        fi
        exec bash "$VAULT_PATH/scripts/ark-dashboard.sh" "$@"
        ;;
      *)
        if [[ ! -f "$VAULT_PATH/scripts/ark-dashboard.sh" ]]; then
          echo -e "${RED}❌ scripts/ark-dashboard.sh not found — Phase 6.5 not yet installed${NC}" >&2
          exit 1
        fi
        exec bash "$VAULT_PATH/scripts/ark-dashboard.sh" "$@"
        ;;
    esac
    ;;
  observe)    shift; bash "$VAULT_PATH/scripts/ark-observer.sh" "$@" ;;
  continuous) shift; cmd_continuous "$@" ;;
  context)    shift; bash "$VAULT_PATH/scripts/ark-context.sh" "$@" ;;
  create)     shift; cmd_create "$@" ;;
  deliver)    shift; bash "$VAULT_PATH/scripts/ark-deliver.sh" "$@" ;;
  promote)    shift; bash "$VAULT_PATH/scripts/ark-promote.sh" "$@" ;;
  budget)     shift; bash "$VAULT_PATH/scripts/ark-budget.sh" "$@" ;;
  escalations) shift; bash "$VAULT_PATH/scripts/ark-escalations.sh" "$@" ;;
  portfolio)  shift; bash "$VAULT_PATH/scripts/ark-portfolio.sh" "$@" ;;
  secrets)    shift; bash "$VAULT_PATH/scripts/ark-secrets.sh" "$@" ;;
  lifecycle)  shift; bash "$VAULT_PATH/scripts/ark-lifecycle.sh" "$@" ;;
  backup)     bash "$VAULT_PATH/scripts/ark-backup.sh" ;;
  validate)   shift; bash "$VAULT_PATH/scripts/ark-validate.sh" "$@" ;;
  report)     shift; bash "$VAULT_PATH/scripts/ark-report.sh" "$@" ;;
  insights)   cmd_insights ;;
  lessons)    cmd_lessons ;;
  promote-lessons)
    shift
    if [[ ! -f "$VAULT_PATH/scripts/lesson-promoter.sh" ]]; then
      echo -e "${RED}❌ scripts/lesson-promoter.sh not found — Phase 6 not yet installed${NC}" >&2
      exit 1
    fi
    case "${1:-}" in
      --full)
        # Sourced + subshell so multi-flag invocation (--full + --apply) works
        # regardless of lesson-promoter.sh CLI dispatcher single-flag limitation.
        ( source "$VAULT_PATH/scripts/lesson-promoter.sh" && promoter_run --full --apply )
        ;;
      --since)
        shift
        if [[ -z "${1:-}" ]]; then
          echo -e "${RED}❌ --since requires an ISO8601 date (e.g., 2026-04-19T00:00:00Z)${NC}" >&2
          exit 1
        fi
        ( source "$VAULT_PATH/scripts/lesson-promoter.sh" && promoter_run --since "$1" --apply )
        ;;
      --dry-run)
        ( source "$VAULT_PATH/scripts/lesson-promoter.sh" && promoter_run --dry-run )
        ;;
      "")
        # Default: last 7 days, with --apply (BSD + GNU date compatible)
        _ark_since=$(date -u -v-7d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
          || date -u -d '7 days ago' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
          || date -u +%Y-%m-%dT%H:%M:%SZ)
        ( source "$VAULT_PATH/scripts/lesson-promoter.sh" && promoter_run --since "$_ark_since" --apply )
        ;;
      *)
        echo -e "${RED}❌ Unknown flag: $1${NC}" >&2
        echo "Usage: ark promote-lessons [--full | --since ISO8601 | --dry-run]" >&2
        exit 1
        ;;
    esac
    ;;
  learn)
    shift
    if [[ ! -f "$VAULT_PATH/scripts/policy-learner.sh" ]]; then
      echo -e "${RED}❌ scripts/policy-learner.sh not found — Phase 3 not yet installed${NC}" >&2
      exit 1
    fi
    case "${1:-}" in
      --full)
        bash "$VAULT_PATH/scripts/policy-learner.sh" --full
        ;;
      --since)
        shift
        if [[ -z "${1:-}" ]]; then
          echo -e "${RED}❌ --since requires an ISO8601 date (e.g., 2026-04-19T00:00:00Z)${NC}" >&2
          exit 1
        fi
        bash "$VAULT_PATH/scripts/policy-learner.sh" --since "$1"
        ;;
      --tag-first)
        if [[ -f "$VAULT_PATH/scripts/lib/outcome-tagger.sh" ]]; then
          bash "$VAULT_PATH/scripts/lib/outcome-tagger.sh" || true
        fi
        _ark_since=$(date -u -v-7d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
          || date -u -d '7 days ago' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
          || date -u +%Y-%m-%dT%H:%M:%SZ)
        bash "$VAULT_PATH/scripts/policy-learner.sh" --since "$_ark_since"
        ;;
      "")
        # Default: last 7 days (BSD + GNU date compatible)
        _ark_since=$(date -u -v-7d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
          || date -u -d '7 days ago' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
          || date -u +%Y-%m-%dT%H:%M:%SZ)
        bash "$VAULT_PATH/scripts/policy-learner.sh" --since "$_ark_since"
        ;;
      *)
        echo -e "${RED}❌ Unknown flag: $1${NC}" >&2
        echo "Usage: ark learn [--full | --since ISO8601 | --tag-first]" >&2
        exit 1
        ;;
    esac
    ;;
  phase-6)    cmd_phase6 ;;
  init)       cmd_init ;;
  help|-h|--help)  cmd_help ;;
  *)
    echo -e "${RED}❌ Unknown command: $COMMAND${NC}"
    cmd_help
    exit 1
    ;;
esac
